#include <iostream>
#include <stdio.h>
#include <algorithm>
#include <cstring>
using namespace std;
int t,n,a[200009],b[200009];
int lcm(int x, int y){
    return x/__gcd(x, y)*y;
}
int main(){
	cin>>t;
	while(t--){
		cin>>n;
		for(int i=1; i<=n; i++){
			cin>>a[i];
		}
		for(int i=1; i<=n; i++){
			cin>>b[i];
		}
		int ans=0;
		for(int i=1; i<=n; i++){
			if(i==1){
				int q=__gcd(a[i],a[i+1]);
				if(a[i]>q) ans++;
				continue;
			}
			if(i==n){
				int p=__gcd(a[i-1],a[i]);
				if(a[i]>p) ans++;
				continue;
			}
			int p=__gcd(a[i-1],a[i]),q=__gcd(a[i],a[i+1]); 
			if(a[i]>lcm(p,q)){
				ans++;
			}
		}
		cout<<ans<<'\n';
	}
	return 0;
}
