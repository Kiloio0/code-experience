//倍增
#include <bits/stdc++.h>
using namespace std;
int n,m,s,head[500002],to[1000002],nex[1000002],tot;
int fa[500002][21],dep[500002];
void add(int u,int v){
	to[++tot]=v,nex[tot]=head[u],head[u]=tot;
}
void dfs(int u,int f){
	fa[u][0]=f,dep[u]=dep[f]+1;
	for(int i=1; i<=20; i++){
		fa[u][i]=fa[fa[u][i-1]][i-1];
	}
	for(int i=head[u]; i!=-1; i=nex[i]){
		if(f==to[i]) continue;
		dfs(to[i],u);
	}
}
int lca(int u,int v){
	if(dep[u]<dep[v]) u^=v,v^=u,u^=v;
	for(int i=20; i>=0; i--){
		if(dep[fa[u][i]]>=dep[v]){
			//cout<<dep[u]<<" "<<dep[fa[u][i]]<<" "<<dep[v]<<endl;
			u=fa[u][i];
		}
	}
	if(u==v) return u;
	for(int i=20; i>=0; i--){
		if(fa[u][i]!=fa[v][i]){
			u=fa[u][i],v=fa[v][i];
		}
	}
	return fa[u][0];
}
int main(){
	cin>>n>>m>>s;
	memset(head,-1,sizeof(head));
	int u,v;
	for(int i=1; i<n; i++){
		cin>>u>>v;
		add(u,v),add(v,u);
	}
	dfs(s,0);
	for(int i=1; i<=m; i++){
		cin>>u>>v;
		cout<<lca(u,v)<<'\n';
	}
	return 0;
}
